<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Deletion Speed"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Higher batches are faster but may use more system resources. Choose '1' for safest operation."
        android:textColor="#666666"
        android:textSize="13sp"
        android:paddingBottom="16dp" />

    <RadioGroup
        android:id="@+id/batch_options_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_batch_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 (Single - One by one)"
            android:padding="10dp"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radio_batch_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5 at a time"
            android:padding="10dp"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radio_batch_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10 at a time"
            android:padding="10dp"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radio_batch_15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="15 at a time"
            android:padding="10dp"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radio_batch_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20 at a time"
            android:padding="10dp"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radio_batch_30"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30 at a time"
            android:padding="10dp"
            android:textSize="15sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="10dp">

        <Button
            android:id="@+id/btn_batch_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="?android:attr/colorPrimary" />

        <Button
            android:id="@+id/btn_batch_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete Now"
            android:backgroundTint="?android:attr/colorPrimary"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>